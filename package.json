{
  "name": "weddingplanner",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "nuxt build",
    "dev": "nuxt dev",
    "dev:stripe": "stripe listen --forward-to localhost:3000/api/subscriptions/webhook",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "db:seed": "npx tsx server/db/seed.ts",
    "db:seed-templates": "npx tsx server/db/seed-templates.ts",
    "db:push": "mkdir -p db && npx drizzle-kit push",
    "db:generate": "npx drizzle-kit generate",
    "db:migrate": "tsx server/db/migrate.ts",
    "templates:screenshots": "tsx server/db/templates-screenshots.ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@nuxtjs/i18n": "^10.2.4",
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.8.0",
    "drizzle-orm": "^0.45.1",
    "jsonwebtoken": "^9.0.3",
    "nuxt": "^3.21.2",
    "openai": "^6.29.0",
    "puppeteer": "^24.39.1",
    "resend": "^6.9.3",
    "stripe": "^20.4.1",
    "vue": "^3.5.30",
    "vue-router": "^5.0.3"
  },
  "devDependencies": {
    "@nuxtjs/tailwindcss": "^6.14.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/better-sqlite3": "^7.6.13",
    "@types/jsonwebtoken": "^9.0.10",
    "drizzle-kit": "^0.31.9",
    "tsx": "^4.21.0",
    "vitest": "^4.1.0"
  }
}
